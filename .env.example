NODE_ENV=development
PORT=3000
LOG_LEVEL=info
DATABASE_URL=postgresql://cartsuna:cartsuna@localhost:5432/cartsuna_dev
DB_POOL_MIN=2
DB_POOL_MAX=10
DB_IDLE_TIMEOUT_MS=30000
REDIS_URL=redis://localhost:6379
REDIS_KEY_PREFIX=cartsuna:
JWT_SECRET=<REQUIRED>
JWT_EXPIRES_IN=15m
REFRESH_TOKEN_SECRET=<REQUIRED>
REFRESH_TOKEN_EXPIRES_IN=7d
S3_BUCKET=
S3_REGION=
S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
FEATURE_RECOMMENDATIONS_ENABLED=false
FEATURE_BLUETOOTH_ENABLED=false
FEATURE_ADMIN_PORTAL_ENABLED=false
BULLMQ_CONCURRENCY=5
BULLMQ_STALE_SESSION_CRON=*/5 * * * *
